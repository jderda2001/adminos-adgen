# Konfiguracja produkcyjna — skopiuj na serwerze do pliku `.env` i uzupełnij.
# NIE commituj prawdziwego `.env`.

# Ścieżka do bazy SQLite — użyj ŚCIEŻKI BEZWZGLĘDNEJ (unikasz niespodzianek z cwd).
# Baza i katalog uploads/ muszą przetrwać aktualizacje (git pull) — trzymaj je poza
# obszarem czyszczonym przy wdrożeniu.
DATABASE_URL="file:/var/www/adgen-finanse/prisma/adgen.db"

# HTTPS: ustaw 1, gdy aplikacja jest za HTTPS (np. `tailscale serve`).
# Zostaw 0/puste, jeśli łączysz się po zwykłym HTTP po tailnecie.
AUTH_SECURE_COOKIE=1

# Port, na którym nasłuchuje Next (proxy Tailscale kieruje na 127.0.0.1:PORT).
PORT=3000

NODE_ENV=production

# Używane TYLKO przez `npm run db:bootstrap` przy pierwszej inicjalizacji.
# Po utworzeniu konta możesz je usunąć z pliku .env.
ADMIN_EMAIL="admin@adgen.pl"
ADMIN_PASSWORD="zmien-to-na-mocne-haslo"
ADMIN_NAME="Jakub Derda"
