// System finansowy adGen — schemat bazy danych
// SQLite (łatwa migracja do Postgresa: brak enumów — statusy jako String + stałe TS,
// kwoty w groszach jako Int, daty jako DateTime)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Użytkownicy i sesje ──────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               String    @default("EMPLOYEE") // ADMIN | EMPLOYEE
  active             Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  monthlyBudgetGr    Int? // założenie miesięczne (budżet wypłaty) do rozliczenia zespołu
  createdAt          DateTime  @default(now())

  sessions     Session[]
  rates        HourlyRate[]
  timeEntries  TimeEntry[]
  activeTimer  ActiveTimer?
  costComments CostComment[]
}

model Session {
  id        String   @id // losowy token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Historia stawek kosztowych — stawka obowiązuje od validFrom (włącznie)
model HourlyRate {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratePerHourGr Int // grosze za godzinę
  validFrom     DateTime
  createdAt     DateTime @default(now())

  @@index([userId, validFrom])
}

// ── Klienci ──────────────────────────────────────────────────────────

model Client {
  id                String    @id @default(cuid())
  name              String
  nip               String?
  contactPerson     String?
  email             String?
  phone             String?
  address           String?
  billingModel      String    @default("ABONAMENT") // ABONAMENT | PROJEKT | SUCCESS_FEE
  monthlyRetainerGr Int? // MRR w groszach (dla modelu abonamentowego)
  offerTags         String? // tagi oferty rozdzielone przecinkami, np. "META ADS ABO,PAKIETY LEADÓW"
  status            String    @default("ACTIVE") // ACTIVE | ENDED
  contractType      String    @default("INDEFINITE_NOTICE") // INDEFINITE_NOTICE | ONE_OFF_MONTH | ONE_OFF_PROJECT
  billingTiming     String    @default("UPFRONT") // UPFRONT (z góry) | ARREARS (z dołu)
  startDate         DateTime?
  endDate           DateTime? // koniec współpracy — estymacje liczą MRR do miesiąca endDate włącznie
  noticeMonths      Int? // okres wypowiedzenia w miesiącach (wyprowadzany z contractType)
  noticeGivenDate   DateTime? // data złożenia wypowiedzenia (ustawia endDate wg okresu wypowiedzenia)
  notes             String?
  createdAt         DateTime  @default(now())

  invoices       Invoice[]
  costs          Cost[]
  timeEntries    TimeEntry[]
  recurringCosts RecurringCost[]
  activeTimers   ActiveTimer[]
  planNotes      RevenuePlanNote[]
  leadDeliveries LeadDelivery[]
}

// ── Faktury sprzedażowe (przychody) ─────────────────────────────────

model Invoice {
  id        String    @id @default(cuid())
  number    String?   @unique // opcjonalny — „bez fv" gdy faktura jeszcze niewystawiona
  label     String? // opis pozycji przychodu, np. „Klient | SKD"
  offerTags String? // tagi oferty na wierszu, po przecinku
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id])
  issueDate DateTime // data wystawienia
  saleDate  DateTime // data sprzedaży — do tego miesiąca liczony przychód
  dueDate   DateTime // termin płatności
  status    String    @default("DRAFT") // DRAFT(bez fv) | ISSUED(wysłana) | PAID(opłacona) | OVERDUE(przeterminowana)
  paidDate  DateTime?
  netGr     Int       @default(0) // kwota netto (zdenormalizowana; suma pozycji jeśli istnieją)
  vatGr     Int       @default(0)
  grossGr   Int       @default(0)
  // Paczki leadów (oferta PAKIETY LEADÓW): netto = leadsQty × leadUnitPriceGr.
  // null gdy przychód nie jest paczką leadów (kwota wpisana wprost).
  leadsQty       Int? // liczba sprzedanych leadów na fakturze
  leadUnitPriceGr Int? // cena jednostkowa leada NETTO w groszach
  leadActivationFeeGr Int? // opłata aktywacyjna NETTO (gr) — doliczana do netto paczki
  // % gwarancji: leady dorzucane gratis PONAD zapłacone (50 szt. + 10% → kontrakt
  // 55 do dowiezienia); NIE wpływa na kwotę faktury. null = brak gwarancji.
  leadGuaranteePct Int?
  notes     String?
  createdAt DateTime  @default(now())

  items InvoiceItem[]

  @@index([clientId])
  @@index([saleDate])
  @@index([status])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  name      String
  quantity  Float // ilość (np. 1.5) — kwoty liczone raz i zapisywane w groszach
  unitNetGr Int // cena jedn. netto w groszach
  vatRate   String  @default("23") // 23 | 8 | 5 | 0 | ZW
  netGr     Int // zaokrąglone: quantity × unitNetGr
  vatGr     Int
  grossGr   Int
  position  Int     @default(0)
}

// ── Koszty ───────────────────────────────────────────────────────────

model CostCategory {
  id         String  @id @default(cuid())
  name       String  @unique
  position   Int     @default(0)
  isSalary   Boolean @default(false) // kategoria wynagrodzeń: rozliczana kosztem pracy z godzin, poza alokacją
  isDeferred Boolean @default(false) // koszt wewnętrzny/odłożony (zaliczki CIT/premie, oszczędności) — przelew na własne konto; NIE liczony jako koszt zewnętrzny w zysku/rentowności
  isAdBudget Boolean @default(false) // budżet reklamowy: poza kosztami bezpośrednimi i pulą alokacji — klientom przypisywany jest koszt leadów z modułu Leady

  costs          Cost[]
  recurringCosts RecurringCost[]
}

model Cost {
  id                String    @id @default(cuid())
  supplierName      String
  supplierAccount   String? // nr rachunku (NRB, 26 cyfr) — wymagany do eksportu Elixir
  docNumber         String
  docDate           DateTime // data dokumentu — do tego miesiąca liczony koszt
  dueDate           DateTime? // termin płatności (moduł Płatności)
  netGr             Int
  vatRate           String    @default("23") // 23 | 8 | 5 | 0 | ZW
  vatGr             Int
  grossGr           Int
  categoryId        String
  category          CostCategory @relation(fields: [categoryId], references: [id])
  clientId          String? // null = koszt ogólny firmy
  client            Client?   @relation(fields: [clientId], references: [id])
  paid              Boolean   @default(false)
  paidDate          DateTime?
  approvedForPayment Boolean  @default(false) // "Można płacić" — zatwierdzenie do płatności (dwustopniowy flow)
  delayed           Boolean   @default(false) // "Opóźniamy" — świadome wstrzymanie płatności
  needsConfirmation Boolean   @default(false) // kopia z kosztu cyklicznego czeka na zatwierdzenie
  note              String?
  attachmentPath    String? // ścieżka w /uploads
  attachmentName    String? // oryginalna nazwa pliku
  recurringCostId   String?
  recurringCost     RecurringCost? @relation(fields: [recurringCostId], references: [id], onDelete: SetNull)
  comments          CostComment[]
  createdAt         DateTime  @default(now())

  @@index([docDate])
  @@index([clientId])
  @@index([categoryId])
  @@index([paid])
}

// Komentarz do kosztu — historia z autorem (kto i kiedy). authorName to snapshot
// (historia czytelna nawet po zmianie nazwy/usunięciu konta); authorId FK do User
// (SetNull po usunięciu). Append-only; autor może usunąć własny wpis.
model CostComment {
  id         String   @id @default(cuid())
  costId     String
  cost       Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String
  body       String
  createdAt  DateTime @default(now())

  @@index([costId])
}

// Szablon kosztu cyklicznego — 1. dnia miesiąca (generowanie leniwe przy
// wejściu na stronę Kosztów/Płatności) tworzy kopię Cost z needsConfirmation=true
model RecurringCost {
  id                  String  @id @default(cuid())
  active              Boolean @default(true)
  supplierName        String
  supplierAccount     String?
  docNumber           String? // baza numeru dokumentu, np. "Abonament {MM/RRRR}"
  netGr               Int
  vatRate             String  @default("23")
  categoryId          String
  category            CostCategory @relation(fields: [categoryId], references: [id])
  clientId            String?
  client              Client? @relation(fields: [clientId], references: [id])
  dueDayOfMonth       Int     @default(10) // dzień miesiąca jako termin płatności kopii
  note                String?
  lastGeneratedPeriod String? // "RRRR-MM" ostatnio wygenerowanego miesiąca
  endPeriod           String? // "RRRR-MM" OSTATNI generowany miesiąc (raty/leasingi) — potem koszt znika też z estymacji
  createdAt           DateTime @default(now())

  costs Cost[]
}

// ── Estymacje (prognoza finansowa) ───────────────────────────────────

// Ręcznie wpisywany ŁĄCZNY stan kont firmy na daną datę — najnowszy wpis
// kotwiczy prognozę cash flow (wyciągi bankowe nie niosą salda). Konwencja:
// suma wszystkich kont, dlatego przelewy na oszczędności są w prognozie
// neutralne (przepływ wewnętrzny).
model CashSnapshot {
  id        String   @id @default(cuid())
  date      DateTime // stan na ten dzień
  balanceGr Int // grosze, stan łączny
  note      String?
  createdAt DateTime @default(now())

  @@index([date])
}

// Jednorazowe planowane zdarzenie gotówkowe (BRUTTO — realny przepływ):
// planowany zakup sprzętu, spodziewana premia od klienta, zwrot podatku itp.
// Wpływa wyłącznie na cash flow (nie na P&L estymacji).
model FinPlanEvent {
  id        String   @id @default(cuid())
  period    String // "RRRR-MM"
  kind      String // INFLOW | OUTFLOW
  label     String
  amountGr  Int // BRUTTO, zawsze dodatnia (kierunek nadaje kind)
  note      String?
  createdAt DateTime @default(now())

  @@index([period])
}

// ── Czas pracy ───────────────────────────────────────────────────────

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  date        DateTime
  minutes     Int // czas w minutach (1,5 h = 90)
  description String?
  createdAt   DateTime @default(now())

  @@index([userId, date])
  @@index([clientId, date])
}

model ActiveTimer {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  description String?
  startedAt   DateTime @default(now())
}

// Budżet miesięczny (plan) firmy — zamrażany na początek miesiąca, porównywany
// z wykonaniem (faktury/koszty/dostawy leadów) w module Budżet. Kwoty NETTO gr.
model MonthlyBudget {
  id            String   @id @default(cuid())
  period        String   @unique // "RRRR-MM"
  revenuePlanGr Int      @default(0)
  costPlanGr    Int      @default(0)
  leadsPlan     Int?     // plan dostarczonych leadów (opcjonalny)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Miesięczna uwaga do klienta w planie przychodów (np. "w tym miesiącu brak prowizji")
model RevenuePlanNote {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period   String // "RRRR-MM"
  note     String

  @@unique([clientId, period])
}

// ── Ekonomika leadów (moduł Leady) ───────────────────────────────────
// Marki wewnętrzne agencji prowadzą kampanie leadowe na wspólnym koncie
// Meta (nazwy marek poza repo — config/brands.json). Miesięczne wyniki (marka × wertykal)
// przepisywane z Meta Ads Manager dają CPL; dostawy leadów do klientów
// wyliczają koszt leadów per klient (leady × CPL) — wchodzi do rentowności.

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  campaigns  LeadCampaignMonth[]
  deliveries LeadDelivery[]
}

// Wertykał leadowy (nisza: SKD, OZE, Kredyty…). Edytowalny w module Leady;
// startowe wartości z DEFAULT_VERTICALS (lib/types.ts). Kampanie/dostawy trzymają
// nazwę wertykalu jako String (spójny z name) — brak twardego FK dla prostoty.
model LeadVertical {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

// Miesięczny wynik kampanii marka × wertykal — spend i liczba leadów
// z Meta Ads Manager. Kwoty NETTO w groszach. CPL = spendGr / leadsCount.
model LeadCampaignMonth {
  id         String   @id @default(cuid())
  period     String // "RRRR-MM"
  brandId    String
  brand      Brand    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  vertical   String // wartość z LEAD_CATEGORIES (lib/types.ts)
  spendGr    Int // wydatki NETTO w groszach
  leadsCount Int
  note       String?
  source     String   @default("MANUAL") // MANUAL | META — proweniencja; sync z Mety nie nadpisuje MANUAL
  createdAt  DateTime @default(now())

  @@unique([period, brandId, vertical])
  @@index([period])
}

// Mapowanie kampanii Meta → marka + wertykal (wspólne/wiele kont reklamowych).
// Kampanie zaciągane z całego portfolio; brandId/vertical null = niezmapowana;
// ignored = pomijana (np. nie-leadowa). Klucz: metaCampaignId (globalnie unikalny).
// Mapowanie KONTA reklamowego Meta → marka wewnętrzna (albo „konto klienta" =
// ignored, pomijane w całości). Kampanie dziedziczą markę z konta — w dialogu
// przypisuje się im już tylko wertykal.
model MetaAdAccountMap {
  id            String   @id @default(cuid())
  adAccountId   String   @unique
  adAccountName String
  brandId       String?
  mixed         Boolean  @default(false) // konto wielu marek — marka wybierana per kampania
  ignored       Boolean  @default(false)
  lastSeenAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Miesięczny plan budżetu reklamowego per marka wewnętrzna („żeby się spięło"):
// karta marki pokazuje wydane wg Mety vs plan i ile zostało do wydania.
model BrandBudget {
  id       String @id @default(cuid())
  period   String // "RRRR-MM"
  brandId  String
  budgetGr Int // plan NETTO w groszach

  @@unique([period, brandId])
  @@index([period])
}

model MetaCampaignMap {
  id               String   @id @default(cuid())
  metaCampaignId   String   @unique
  metaCampaignName String
  adAccountId      String
  adAccountName    String
  brandId          String?
  vertical         String?
  ignored          Boolean  @default(false)
  lastSeenAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Log synchronizacji z Meta (status „ostatnia synchronizacja" + błędy).
model MetaSyncRun {
  id              String   @id @default(cuid())
  ranAt           DateTime @default(now())
  month           String // "RRRR-MM"
  ok              Boolean
  campaignsPulled Int      @default(0)
  mappedCount     Int      @default(0)
  unmappedSpendGr Int      @default(0)
  error           String?
}

// Dostawa leadów do klienta w miesiącu. brandId null = mix marek →
// rozliczenie po średniej ważonej CPL wertykalu. Celowo BEZ unique —
// klient może mieć kilka paczek w miesiącu, koszty się sumują.
model LeadDelivery {
  id         String   @id @default(cuid())
  period     String // "RRRR-MM"
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  vertical   String
  brandId    String?
  brand      Brand?   @relation(fields: [brandId], references: [id], onDelete: Restrict)
  leadsCount Int
  note       String?
  estimated  Boolean  @default(false) // auto-przeniesione z poprzedniego miesiąca (do potwierdzenia/korekty)
  createdAt  DateTime @default(now())

  @@index([period])
  @@index([clientId, period])
}

// ── Rachunek wyników (RW) — najważniejszy moduł ─────────────────────
// Dane kasowe importowane z CSV (przychody/koszty wg kategorii arkusza RW).
// Kwoty w groszach: przychody dodatnie, koszty/odłożone/CIT ujemne.

model RwImportBatch {
  id           String   @id @default(cuid())
  filename     String
  kind         String // PRZYCHOD | KOSZT | BANK
  year         Int
  rowCount     Int
  /// JSON: [{name, number}] — konta z preambuły wyciągu (kontrola kompletności)
  accountsJson String?
  createdAt    DateTime @default(now())

  entries RwEntry[]
}

model RwEntry {
  id          String  @id @default(cuid())
  year        Int
  month       Int // 1–12
  kind        String // PRZYCHOD | KOSZT
  category    String // kanoniczna nazwa kategorii z lib/rw-types (RW_CATEGORIES)
  amountGr    Int // grosze NETTO; przychody +, koszty − (używane we wszystkich wyliczeniach)
  grossGr     Int? // grosze BRUTTO z wyciągu (referencja; null dla starych/ręcznych wpisów)
  vatRate     Int? // zastosowana stawka VAT w % (23|8|5|0); null = nieustalona (traktuj jak brutto=netto)
  vatKey      String? // klucz kontrahenta do reguł VAT ([[RwVatRule.matchKey]]) — spójny import↔edycja
  description String? // opis/klient z CSV (skrócony)
  contractor  String? // kontrahent (koszty)
  bank        String? // NestBank / mBank
  note        String? // uwagi
  source      String  @default("IMPORT") // IMPORT | MANUAL
  batchId     String?
  batch       RwImportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([year, month])
  @@index([year, kind, category])
  @@index([batchId])
}

// Referencja per kontrahent — uczy się przy zatwierdzaniu importu i edycji.
// Zapamiętuje STAWKĘ VAT oraz KATEGORIĘ wybraną przez użytkownika, żeby przy
// kolejnym imporcie automatycznie je podpowiedzieć. Klucz (matchKey) liczony
// z opisu/konta w lib/rw-vat.ts. Dane wrażliwe (nazwy) NIE trafiają do repo —
// baza jest poza gitem.
model RwVatRule {
  id        String   @id @default(cuid())
  matchKey  String   @unique // znormalizowany klucz kontrahenta (opis lub „acct:<nr>")
  vatRate   Int // 23 | 8 | 5 | 0
  category  String? // ostatnia kategoria RW przypisana dla tego kontrahenta
  label     String? // czytelny podgląd (ostatni opis) — do wglądu w UI
  hitCount  Int      @default(1)
  updatedAt DateTime @updatedAt
}

// Metryki uzupełniane ręcznie per miesiąc (estymacja zysku, ETH, windykacja,
// leady, nowi klienci itd. — klucze w lib/rw-types RW_MANUAL_METRICS)
model RwManualMetric {
  id        String   @id @default(cuid())
  year      Int
  month     Int // 1–12
  key       String
  valueNum  Float? // wartości liczbowe (zł jako liczba zł, sztuki, %)
  valueText String? // wartości opisowe (np. "2,19 ETH")
  updatedAt DateTime @updatedAt

  @@unique([year, month, key])
}

// ── Ustawienia (klucz-wartość) ───────────────────────────────────────

model Setting {
  key   String @id
  value String
}
